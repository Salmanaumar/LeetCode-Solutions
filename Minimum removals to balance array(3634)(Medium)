from typing import List

class Solution:
    def minRemoval(self, nums: List[int], k: int) -> int:
        # Step 1: Sort the array so we can use sliding window
        nums.sort()
        n = len(nums)

        # l = left pointer of window
        l = 0

        # max_len = length of largest balanced subarray we can keep
        max_len = 0

        # Step 2: Expand right pointer
        for r in range(n):

            # If current window is not balanced,
            # move left pointer forward
            # condition: max <= min * k
            # here max = nums[r], min = nums[l]
            while nums[r] > nums[l] * k:
                l += 1

            # Update longest valid window size
            max_len = max(max_len, r - l + 1)

        # Minimum removals = total length - largest balanced window
        return n - max_len
