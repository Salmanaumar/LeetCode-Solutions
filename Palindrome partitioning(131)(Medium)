Description:-
Given a string s, partition s such that every substring of
the partition is a palindrome. 
Return all possible palindrome partitioning of s.

 
Example 1:
Input: s = "aab"
Output: [["a","a","b"],["aa","b"]]

Example 2:
Input: s = "a"
Output: [["a"]]
 

Constraints:

1 <= s.length <= 16
s contains only lowercase English letters.

class Solution:
    def partition(self, s: str) -> List[List[str]]:
        res = []                       # Stores all valid palindrome partitions
        path = []                      # Current partition path
        
        def ispal(l, r):
            while l < r:               # Check characters from both ends
                if s[l] != s[r]:       # If mismatch, not a palindrome
                    return False
                l += 1                 # Move left pointer right
                r -= 1                 # Move right pointer left
            return True                # Substring is a palindrome
        
        def bt(start):
            if start == len(s):        # If entire string is partitioned
                res.append(path[:])    # Add a copy of current path to result
                return
            
            for end in range(start, len(s)):      # Try all possible end positions
                if ispal(start, end):             # Check if substring is palindrome
                    path.append(s[start:end + 1])# Choose the substring
                    bt(end + 1)                   # Recurse for remaining string
                    path.pop()                    # Backtrack
        
        bt(0)                         # Start backtracking from index 0
        return res                    # Return all palindrome partitions
