class Solution:
    def nextGreatestLetter(self, letters: List[str], target: str) -> str:
        left = 0
        right = len(letters) - 1

        # Binary search to find the smallest letter > target
        while left <= right:
            mid = (left + right) // 2

            if letters[mid] > target:
                # This letter could be the answer, look left for smaller one
                right = mid - 1
            else:
                # letters[mid] <= target, so answer must be on the right
                left = mid + 1

        # If left is within range, return letters[left]
        # Otherwise, wrap around and return the first letter
        return letters[left] if left < len(letters) else letters[0]
