class Solution:
    def minimumCost(self, nums, k, dist):
        n = len(nums)                 # Length of the array

        small = []                    # Stores the (k-1) smallest elements in the current window
        large = []                    # Stores the remaining larger elements
        sumSmall = 0                  # Sum of elements in `small`
        ans = math.inf                # Best (minimum) sum of (k-1) elements found so far

        def add(x):
            nonlocal sumSmall

            # If we still need more elements to fill `small`
            if len(small) < k - 1:
                insort(small, x)      # Insert x in sorted order
                sumSmall += x         # Update sum
            else:
                # If x is smaller than the largest element in `small`
                if small and x < small[-1]:
                    val = small.pop() # Remove the largest element from `small`
                    sumSmall -= val   # Adjust sum
                    insort(large, val)# Move it to `large`
                    insort(small, x)  # Insert x into `small`
                    sumSmall += x     # Update sum
                else:
                    # Otherwise, x belongs in `large`
                    insort(large, x)

        def remove(x):
            nonlocal sumSmall

            # Try removing x from `small`
            i = bisect_left(small, x)
            if i < len(small) and small[i] == x:
                small.pop(i)          # Remove x from `small`
                sumSmall -= x         # Update sum

                # Rebalance: move smallest element from `large` to `small`
                if large:
                    val = large.pop(0)
                    insort(small, val)
                    sumSmall += val
            else:
                # Otherwise, remove x from `large`
                j = bisect_left(large, x)
                large.pop(j)

        L = 1                          # Left boundary of the sliding window

        # Iterate over possible right boundaries
        for R in range(1, n):
            add(nums[R])               # Add nums[R] to the data structure

            # If window size exceeds `dist`, shrink from the left
            if R - L > dist:
                remove(nums[L])        # Remove element leaving the window
                L += 1                 # Move left pointer

            # If we have exactly (k-1) elements, update answer
            if len(small) == k - 1:
                ans = min(ans, sumSmall)

        # Total cost = nums[0] + sum of chosen (k-1) starting elements
        return nums[0] + ans
