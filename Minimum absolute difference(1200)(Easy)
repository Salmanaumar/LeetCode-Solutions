from typing import List

class Solution:
    def minimumAbsDifference(self, arr: List[int]) -> List[List[int]]:
        # Sort the array so that minimum differences
        # can only occur between adjacent elements
        arr.sort()
        
        # Initialize the minimum difference to a very large value
        min_diff = float('inf')
        
        # First pass: find the minimum absolute difference
        for i in range(1, len(arr)):
            # Since array is sorted, arr[i] - arr[i - 1] is non-negative
            min_diff = min(min_diff, arr[i] - arr[i - 1])
        
        # List to store the result pairs
        result = []
        
        # Second pass: collect all pairs with the minimum difference
        for i in range(1, len(arr)):
            if arr[i] - arr[i - 1] == min_diff:
                # Each pair must be in ascending order: [a, b]
                result.append([arr[i - 1], arr[i]])
        
        # Return all pairs with the minimum absolute difference
        return result


Description:-
Given an array of distinct integers arr, find all pairs of elements with the minimum absolute difference of any two elements.

Return a list of pairs in ascending order(with respect to pairs), each pair [a, b] follows

a, b are from arr
a < b
b - a equals to the minimum absolute difference of any two elements in arr
 

Example 1:

Input: arr = [4,2,1,3]
Output: [[1,2],[2,3],[3,4]]
Explanation: The minimum absolute difference is 1. List all pairs with difference equal to 1 in ascending order.


Example 2:

Input: arr = [1,3,6,10,15]
Output: [[1,3]]


Example 3:

Input: arr = [3,8,-10,23,19,-4,-14,27]
Output: [[-14,-10],[19,23],[23,27]]
 

Constraints:

2 <= arr.length <= 105
-106 <= arr[i] <= 106
