class Solution:
    def candy(self, ratings: List[int]) -> int:
        n = len(ratings)                  # Total number of children
        candies = [1] * n                 # Give each child at least one candy
        
        # First pass: left to right
        for i in range(1, n):             
            if ratings[i] > ratings[i - 1]:      # If current child has higher rating than left neighbor
                candies[i] = candies[i - 1] + 1  # Give one more candy than left neighbor
        
        # Second pass: right to left
        for i in range(n - 2, -1, -1):    
            if ratings[i] > ratings[i + 1]:      # If current child has higher rating than right neighbor
                candies[i] = max(candies[i],     # Keep the larger candy count
                                  candies[i + 1] + 1)  # Ensure more candies than right neighbor
        
        return sum(candies)               # Return minimum total candies required
