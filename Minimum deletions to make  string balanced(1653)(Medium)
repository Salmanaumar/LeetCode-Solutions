class Solution:
    def minimumDeletions(self, s: str) -> int:
        # count_b  -> number of 'b' characters seen so far
        # deletions -> minimum deletions needed to keep string balanced
        count_b = 0
        deletions = 0

        # Traverse the string from left to right
        for ch in s:

            # If current char is 'b', just count it
            # because 'b' before 'a' may cause imbalance later
            if ch == 'b':
                count_b += 1
            else:
                # Current char is 'a'
                # Two choices:
                # 1) Delete this 'a'  -> deletions + 1
                # 2) Delete all previous 'b's -> count_b
                # Take minimum of both options
                deletions = min(deletions + 1, count_b)

        # Final minimum deletions needed
        return deletions
