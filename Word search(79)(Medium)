class Solution:
    def exist(self, board: List[List[str]], word: str) -> bool:
        rows, cols = len(board), len(board[0])   # Number of rows and columns
        
        def bt(r, c, idx):
            if idx == len(word):                 # All characters in word are matched
                return True
            
            # Check boundaries and character match
            if r < 0 or r >= rows or c < 0 or c >= cols or board[r][c] != word[idx]:
                return False
            
            temp = board[r][c]                   # Store current cell value
            board[r][c] = "#"                    # Mark cell as visited
            
            # Explore all four possible directions
            found = (
                bt(r + 1, c, idx + 1) or         # Move down
                bt(r - 1, c, idx + 1) or         # Move up
                bt(r, c + 1, idx + 1) or         # Move right
                bt(r, c - 1, idx + 1)            # Move left
            )
            
            board[r][c] = temp                   # Restore original value (backtrack)
            return found
        
        # Try starting the word from every cell
        for i in range(rows):
            for j in range(cols):
                if bt(i, j, 0):                  # Start backtracking from this cell
                    return True
        
        return False                             # Word not found in the board

 
