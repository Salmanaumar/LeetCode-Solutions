class Solution:
    def coinChange(self, coins: List[int], amount: int) -> int:
        
        dp = [amount + 1] * (amount + 1)   # dp[i] = minimum coins needed to make amount i
        dp[0] = 0                           # 0 coins are needed to make amount 0
        
        # Iterate over each coin denomination
        for i in coins:
            
            # Update dp values for all amounts >= coin value
            for j in range(i, amount + 1):
                dp[j] = min(dp[j], 1 + dp[j - i])  # Choose min between using or not using coin
        
        # If dp[amount] was updated, return result
        if dp[amount] != (amount + 1):
            return dp[amount]
        else:
            return -1                              # Return -1 if amount cannot be formed
