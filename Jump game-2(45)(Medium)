class Solution:
    def jump(self, nums: List[int]) -> int:
        j = 0      # number of jumps taken
        f = 0      # farthest index reachable so far
        c = 0      # end of the current jump range
        n = len(nums)

        # We don't need to jump from the last index
        for i in range(n - 1):

            # Update the farthest position we can reach
            f = max(f, nums[i] + i)

            # If we have reached the end of the current jump range
            if i == c:
                j += 1        # we must make a jump
                c = f         # update the range for the next jump

        return j
