Description:-
Given an array nums of n integers, return an array of all
the unique quadruplets [nums[a], nums[b], nums[c], nums[d]] such that:

0 <= a, b, c, d < n
a, b, c, and d are distinct.
nums[a] + nums[b] + nums[c] + nums[d] == target
You may return the answer in any order.


Example 1:

Input: nums = [1,0,-1,0,-2,2], target = 0
Output: [[-2,-1,1,2],[-2,0,0,2],[-1,0,0,1]]


Example 2:

Input: nums = [2,2,2,2,2], target = 8
Output: [[2,2,2,2]]
 

Constraints:

1 <= nums.length <= 200
-109 <= nums[i] <= 109
-109 <= target <= 109


from typing import List

class Solution:
    def fourSum(self, nums: List[int], target: int) -> List[List[int]]:
        # Sort the array to make it easier to avoid duplicates
        # and to use the two-pointer technique
        nums.sort()
        n = len(nums)
        result = []

        # First loop: fix the first number
        for i in range(n - 3):
            # Skip duplicate values for the first number
            if i > 0 and nums[i] == nums[i - 1]:
                continue

            # Second loop: fix the second number
            for j in range(i + 1, n - 2):
                # Skip duplicate values for the second number
                if j > i + 1 and nums[j] == nums[j - 1]:
                    continue

                # Two pointers for the remaining two numbers
                left = j + 1
                right = n - 1

                # While there are elements between left and right
                while left < right:
                    # Calculate the sum of the four selected numbers
                    current_sum = nums[i] + nums[j] + nums[left] + nums[right]

                    if current_sum == target:
                        # Found a valid quadruplet
                        result.append([nums[i], nums[j], nums[left], nums[right]])

                        # Move left pointer to the next different number
                        left += 1
                        while left < right and nums[left] == nums[left - 1]:
                            left += 1

                        # Move right pointer to the previous different number
                        right -= 1
                        while left < right and nums[right] == nums[right + 1]:
                            right -= 1

                    elif current_sum < target:
                        # Sum is too small, move left pointer to increase sum
                        left += 1
                    else:
                        # Sum is too large, move right pointer to decrease sum
                        right -= 1

        # Return all unique quadruplets
        return result
