Description:-
The n-queens puzzle is the problem of placing n queens on 
an n x n chessboard such that no two queens attack each other.

Given an integer n, return all distinct solutions to the 
n-queens puzzle. You may return the answer in any order.

Each solution contains a distinct board configuration of the
n-queens' placement, where 'Q' and '.' both indicate a queen and an empty space, respectively.

 
Example 1:
Input: n = 4
Output: [[".Q..","...Q","Q...","..Q."],["..Q.","Q...","...Q",".Q.."]]
Explanation: There exist two distinct solutions to the 4-queens puzzle as shown above


Example 2:
Input: n = 1
Output: [["Q"]]
 

Constraints:

1 <= n <= 9

class Solution:
    def solveNQueens(self, n: int) -> List[List[str]]:
        board = [['.'] * n for i in range(n)]   # Initialize empty chessboard
        res = []                                # Store all valid solutions
        
        def issafe(r, c, board):
            for i in range(r - 1, -1, -1):      # Check column above current row
                if board[i][c] == 'Q':
                    return False
            
            row, col = r - 1, c - 1              # Check upper-left diagonal
            while row > -1 and col > -1:
                if board[row][col] == 'Q':
                    return False
                row -= 1
                col -= 1
            
            row, col = r - 1, c + 1              # Check upper-right diagonal
            while row > -1 and col < n:
                if board[row][col] == 'Q':
                    return False
                row -= 1
                col += 1
            
            return True                          # Position is safe
        
        def bt(row, n, board, res):
            if row == n:                         # All queens placed successfully
                res.append(["".join(row) for row in board])  # Save board state
                return 
            
            for col in range(n):                 # Try placing queen in each column
                if issafe(row, col, board):      # Check if placement is valid
                    board[row][col] = 'Q'        # Place queen
                    bt(row + 1, n, board, res)   # Recurse to next row
                    board[row][col] = '.'        # Remove queen (backtrack)
        
        bt(0, n, board, res)                     # Start backtracking from first row
        return res                               # Return all valid solutions
