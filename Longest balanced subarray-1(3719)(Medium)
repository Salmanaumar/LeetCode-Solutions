from typing import List
from collections import defaultdict

class Solution:
    def longestBalanced(self, nums: List[int]) -> int:
        n = len(nums)
        ans = 0  # stores the maximum length of balanced subarray found

        # Try every index as starting point of subarray
        for i in range(n):
            freq = defaultdict(int)  # frequency map of numbers in current window
            evenDistinct = 0         # count of distinct even numbers
            oddDistinct = 0          # count of distinct odd numbers

            # Extend the subarray from i to the right
            for j in range(i, n):
                x = nums[j]
                freq[x] += 1

                # If this number appears for the first time in this subarray
                # update distinct even/odd counters
                if freq[x] == 1:
                    if x % 2 == 0:
                        evenDistinct += 1
                    else:
                        oddDistinct += 1

                # A subarray is balanced if distinct even == distinct odd
                if evenDistinct == oddDistinct:
                    ans = max(ans, j - i + 1)

        return ans
