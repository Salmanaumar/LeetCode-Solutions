from typing import List
import heapq

class Solution:
    def minCost(self, grid: List[List[int]], k: int) -> int:
        # Number of rows and columns
        m, n = len(grid), len(grid[0])

        # A very large number representing infinity
        INF = 10**18

        # dist[i][j][t] = minimum cost to reach cell (i, j)
        # using exactly t teleportations
        dist = [[[INF] * (k + 1) for _ in range(n)] for _ in range(m)]

        # Starting point (0, 0) with 0 cost and 0 teleports used
        dist[0][0][0] = 0

        # Store all cells as (value, row, col)
        # This helps us efficiently find teleport destinations
        cells = []
        for i in range(m):
            for j in range(n):
                cells.append((grid[i][j], i, j))

        # Sort cells by their grid value (ascending)
        cells.sort()

        # Min-heap priority queue
        # Each entry is (current_cost, row, col, teleports_used)
        pq = [(0, 0, 0, 0)]

        # Dijkstra's algorithm
        while pq:
            # Extract the state with the smallest cost
            cost, i, j, t = heapq.heappop(pq)

            # If we already found a better path, skip this one
            if cost > dist[i][j][t]:
                continue

            # If we've reached the bottom-right cell, return the cost
            if i == m - 1 and j == n - 1:
                return cost

            # ----- Normal move: move down -----
            if i + 1 < m:
                # Cost of moving down is the value of the destination cell
                new_cost = cost + grid[i + 1][j]

                # Relax the distance if this path is cheaper
                if new_cost < dist[i + 1][j][t]:
                    dist[i + 1][j][t] = new_cost
                    heapq.heappush(pq, (new_cost, i + 1, j, t))

            # ----- Normal move: move right -----
            if j + 1 < n:
                # Cost of moving right is the value of the destination cell
                new_cost = cost + grid[i][j + 1]

                # Relax the distance if this path is cheaper
                if new_cost < dist[i][j + 1][t]:
                    dist[i][j + 1][t] = new_cost
                    heapq.heappush(pq, (new_cost, i, j + 1, t))

            # ----- Teleportation -----
            # We can only teleport if we haven't used all k teleports
            if t < k:
                # Current cell value (teleport condition)
                current_value = grid[i][j]

                # Try teleporting to every cell with value <= current_value
                for val, x, y in cells:
                    # Since cells are sorted, we can stop early
                    if val > current_value:
                        break

                    # Teleportation has zero cost
                    if cost < dist[x][y][t + 1]:
                        dist[x][y][t + 1] = cost
                        heapq.heappush(pq, (cost, x, y, t + 1))

        # If destination is unreachable (should not happen in valid inputs)
        return -1



Description:-
You are given a m x n 2D integer array grid and an integer k. 
You start at the top-left cell (0, 0) and your goal is to reach the bottom‐right cell (m - 1, n - 1).

There are two types of moves available:

Normal move: You can move right or down from your current cell (i, j), i.e. 
you can move to (i, j + 1) (right) or (i + 1, j) (down). The cost is the value of the destination cell.

Teleportation: You can teleport from any cell (i, j), to any cell (x, y) 
such that grid[x][y] <= grid[i][j]; the cost of this move is 0. You may teleport at most k times.

Return the minimum total cost to reach cell (m - 1, n - 1) from (0, 0).

 

Example 1:

Input: grid = [[1,3,3],[2,5,4],[4,3,5]], k = 2
Output: 7
Explanation:
Initially we are at (0, 0) and cost is 0.

Current Position	Move	New Position	Total Cost
(0, 0)	Move Down	(1, 0)	0 + 2 = 2
(1, 0)	Move Right	(1, 1)	2 + 5 = 7
(1, 1)	Teleport to (2, 2)	(2, 2)	7 + 0 = 7
The minimum cost to reach bottom-right cell is 7.


Example 2:

Input: grid = [[1,2],[2,3],[3,4]], k = 1
Output: 9
Explanation:

Initially we are at (0, 0) and cost is 0.

Current Position	Move	New Position	Total Cost
(0, 0)	Move Down	(1, 0)	0 + 2 = 2
(1, 0)	Move Right	(1, 1)	2 + 3 = 5
(1, 1)	Move Down	(2, 1)	5 + 4 = 9
The minimum cost to reach bottom-right cell is 9.

 

Constraints:

2 <= m, n <= 80
m == grid.length
n == grid[i].length
0 <= grid[i][j] <= 104
0 <= k <= 10
 
