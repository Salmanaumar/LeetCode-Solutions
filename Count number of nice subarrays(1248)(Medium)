Description:-
Given an array of integers nums and an integer k. 
A continuous subarray is called nice if there are k odd numbers on it.
Return the number of nice sub-arrays.

 
Example 1:
Input: nums = [1,1,2,1,1], k = 3
Output: 2
Explanation: The only sub-arrays with 3 odd numbers are [1,1,2,1] and [1,2,1,1].


Example 2:
Input: nums = [2,4,6], k = 1
Output: 0
Explanation: There are no odd numbers in the array.


Example 3:
Input: nums = [2,2,2,1,2,2,1,2,2,2], k = 2
Output: 16
 
class Solution:
    def numberOfSubarrays(self, nums: List[int], k: int) -> int:
        prefix_sum = 0            # Number of odd numbers seen so far
        count = {0: 1}            # Base case: no odd numbers yet
        ans = 0                   # Final answer

        for num in nums:
            # Convert odd number to 1, even number to 0
            if num % 2 == 1:
                prefix_sum += 1

            # Check how many previous prefix sums allow
            # current subarray to have exactly k odd numbers
            if prefix_sum - k in count:
                ans += count[prefix_sum - k]

            # Store/update current prefix sum frequency
            if prefix_sum in count:
                count[prefix_sum] += 1
            else:
                count[prefix_sum] = 1

        return ans
