class Solution:
    def isBalanced(self, root: Optional[TreeNode]) -> bool:

        # This helper function returns:
        #   -> height of the subtree if it is balanced
        #   -> -1 if the subtree is NOT balanced
        # Using -1 lets us stop early without extra checks.
        def height(node):

            # If node is None, height is 0
            if not node:
                return 0
            
            # Get height of left subtree
            left_height = height(node.left)

            # If left subtree already unbalanced, propagate -1 upward
            if left_height == -1:
                return -1
            
            # Get height of right subtree
            right_height = height(node.right)

            # If right subtree already unbalanced, propagate -1 upward
            if right_height == -1:
                return -1
            
            # Check balance condition:
            # difference between left and right subtree heights
            # must not exceed 1
            if abs(left_height - right_height) > 1:
                return -1
            
            # Return height of current node
            return 1 + max(left_height, right_height)
        
        # If height(root) returns -1 → tree is not balanced
        # otherwise it is balanced
        return height(root) != -1

