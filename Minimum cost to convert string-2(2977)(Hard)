class Solution:
    def minimumCost(self, source: str, target: str,
                    original: List[str], changed: List[str], cost: List[int]) -> int:

        from collections import defaultdict

        n = len(source)                          # Length of source / target
        INF = 10**18                             # Large value representing infinity

        # Step 1: Store minimum cost for each (original -> changed) mapping
        mp = {}
        for o, c, z in zip(original, changed, cost):
            if (o, c) not in mp:
                mp[(o, c)] = z
            else:
                mp[(o, c)] = min(mp[(o, c)], z)

        # Step 2: Collect all unique substrings involved in transformations
        subs = set()
        for o, c in mp:
            subs.add(o)
            subs.add(c)

        subs = list(subs)                        # Convert set to list
        idx = {s: i for i, s in enumerate(subs)}# Map substring to index
        m = len(subs)                            # Total unique substrings

        # Step 3: Initialize distance matrix for Floyd–Warshall
        dist = [[INF] * m for _ in range(m)]
        for i in range(m):
            dist[i][i] = 0                       # Cost to convert substring to itself

        for (o, c), z in mp.items():
            dist[idx[o]][idx[c]] = min(dist[idx[o]][idx[c]], z)

        # Step 4: Floyd–Warshall to allow multi-step conversions
        for k in range(m):
            for i in range(m):
                for j in range(m):
                    if dist[i][k] + dist[k][j] < dist[i][j]:
                        dist[i][j] = dist[i][k] + dist[k][j]

        # Step 5: Group substrings by their length (optimization to avoid TLE)
        by_len = defaultdict(list)
        for s in subs:
            by_len[len(s)].append(s)

        # Step 6: DP array where dp[i] = min cost to convert source[i:]
        dp = [INF] * (n + 1)
        dp[n] = 0                                # Base case: no cost beyond string end

        # Step 7: Fill DP from right to left
        for i in range(n - 1, -1, -1):

            # Option 1: No operation if characters already match
            if source[i] == target[i]:
                dp[i] = dp[i + 1]

            # Option 2: Try all valid substring lengths starting at index i
            for L in by_len:
                if i + L > n:
                    continue

                s1 = source[i:i + L]             # Substring from source
                s2 = target[i:i + L]             # Corresponding substring from target

                if s1 not in idx or s2 not in idx:
                    continue

                cost_transform = dist[idx[s1]][idx[s2]]
                if cost_transform == INF:
                    continue

                dp[i] = min(dp[i], cost_transform + dp[i + L])

        return dp[0] if dp[0] != INF else -1      # Return result or -1 if impossible

