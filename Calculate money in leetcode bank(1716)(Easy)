class Solution:
    def totalMoney(self, n: int) -> int:
        # Number of full weeks
        weeks = n // 7
        # Remaining days after full weeks
        days = n % 7

        total = 0

        # Sum money deposited in full weeks
        # Week w (0-indexed) starts with (w + 1) on Monday
        # Deposits for the week are:
        # (w + 1), (w + 2), ..., (w + 7)
        for w in range(weeks):
            total += 7 * (w + 1) + 21

        # Sum money deposited in the remaining days
        # Starts from (weeks + 1) and increases by 1 each day
        for d in range(days):
            total += weeks + 1 + d

        return total
