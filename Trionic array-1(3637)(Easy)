You are given an integer array nums of length n.
An array is trionic if there exist indices 0 < p < q < n − 1 such that:

nums[0...p] is strictly increasing,
nums[p...q] is strictly decreasing,
nums[q...n − 1] is strictly increasing.
Return true if nums is trionic, otherwise return false.


Example 1:
Input: nums = [1,3,5,4,2,6]
Output: true
Explanation:

Pick p = 2, q = 4:

nums[0...2] = [1, 3, 5] is strictly increasing (1 < 3 < 5).
nums[2...4] = [5, 4, 2] is strictly decreasing (5 > 4 > 2).
nums[4...5] = [2, 6] is strictly increasing (2 < 6).


Example 2:
Input: nums = [2,1,3]
Output: false
Explanation:
There is no way to pick p and q to form the required three segments.

 
Constraints:

3 <= n <= 100
-1000 <= nums[i] <= 1000

class Solution:
    def isTrionic(self, nums: List[int], k: int = 3) -> bool:
        # At beginning nums should be increasing
        if nums[0] >= nums[1]:
            return False

        n = len(nums)

        sign, switches = 1, 0
        for i in range(1, n):
            delta = nums[i] - nums[i - 1]
            if delta == 0:  # Delta should be always decreasing or increasing
                return False
            elif delta * sign < 0:  # Switch point detected
                sign *= -1
                switches += 1

        return switches == k - 1





class Solution:
    def isTrionic(self, nums: List[int], k: int = 3) -> bool:
        # First segment must start with strictly increasing
        # If first two elements are not increasing → impossible
        if nums[0] >= nums[1]:
            return False

        n = len(nums)

        sign = 1        # +1 means currently increasing, -1 means decreasing
        switches = 0    # counts how many times trend changes (inc→dec or dec→inc)

        # Traverse the array and observe direction changes
        for i in range(1, n):
            delta = nums[i] - nums[i - 1]   # difference between neighbours

            # Equal elements break strict increasing/decreasing rule
            if delta == 0:
                return False

            # If sign changes (e.g., + to - or - to +), we found a turning point
            elif delta * sign < 0:
                sign *= -1      # flip expected direction
                switches += 1   # count this switch

        # For a trionic array we need:
        # increasing → decreasing → increasing
        # which means exactly 2 switches (k-1 when k=3 segments)
        return switches == k - 1
